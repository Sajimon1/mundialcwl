{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with Discord username, avatar, and score for prediction leaderboard",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User's unique ID" },
        "username": { "type": "string", "description": "Discord username" },
        "avatarUrl": { "type": "string", "description": "URL of user avatar" },
        "points": { "type": "number", "description": "Total points accumulated from predictions" },
        "isAdmin": { "type": "boolean", "description": "True if the user is an admin" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO timestamp of profile creation" }
      },
      "required": ["uid", "username", "points"]
    },
    "Match": {
      "title": "Match Details",
      "description": "A football match details, including schedule, teams, and final score",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Match ID" },
        "teamA": { "type": "string", "description": "Home team country name" },
        "teamB": { "type": "string", "description": "Away team country name" },
        "group": { "type": "string", "description": "Group name or tournament phase, e.g. Group A, Round of 16" },
        "date": { "type": "string", "format": "date-time", "description": "Match schedule date and time" },
        "status": { "type": "string", "enum": ["scheduled", "live", "finished"], "description": "Current state" },
        "scoreA": { "type": "number", "description": "Home team final score" },
        "scoreB": { "type": "number", "description": "Away team final score" }
      },
      "required": ["id", "teamA", "teamB", "group", "date", "status"]
    },
    "Prediction": {
      "title": "Match Prediction",
      "description": "A user's prediction score for a specific match",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Prediction unique ID (userId_matchId)" },
        "userId": { "type": "string", "description": "ID of predicting user" },
        "username": { "type": "string", "description": "Username of predicting user" },
        "matchId": { "type": "string", "description": "ID of the match projected" },
        "predictedA": { "type": "number", "description": "Predicted score for Home team" },
        "predictedB": { "type": "number", "description": "Predicted score for Away team" },
        "pointsEarned": { "type": "number", "description": "Points earned for this prediction" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "matchId", "predictedA", "predictedB"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles and accumulated points"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Stores details, schedule, and results of all World Cup matches"
    },
    "/predictions/{predictionId}": {
      "schema": "Prediction",
      "description": "Stores prediction entries by users"
    }
  }
}
